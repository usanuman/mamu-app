{
  "schemaVersion": 2,
  "services": [
    {
      "isMain": true,
      "image": "soulteary/cronicle:0.9.80",
      "name": "cronicle",
      "internalPort": 3012,
      "entrypoint": ["/bin/sh", "-c", "apk add --no-cache openssh-client && exec docker-entrypoint.sh node bin/docker-entrypoint.js"],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data",
          "containerPath": "/opt/cronicle/data"
        },
        {
          "hostPath": "${APP_DATA_DIR}/logs",
          "containerPath": "/opt/cronicle/logs"
        },
        {
          "hostPath": "${APP_DATA_DIR}/plugins",
          "containerPath": "/opt/cronicle/plugins"
        },
        {
          "hostPath": "${APP_DATA_DIR}/ssh",
          "containerPath": "/root/.ssh"
        }
      ]
    }
  ]
}
